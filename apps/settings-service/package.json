{
    "name": "@nebula/settings-service",
    "private": true,
    "version": "0.1.0",
    "type": "commonjs",
    "prisma": {
      "schema": "apps/settings-service/prisma/schema.prisma"
    },
    "scripts": {
        "dev": "nest start --watch settings-service",
        "build": "tsc -p apps/settings-service/tsconfig.build.json",
        "start": "node ../../dist/apps/settings-service/main.js",
        "prisma:gen": "prisma generate --schema ./prisma/schema.prisma",
        "prisma:migrate:dev": "prisma migrate dev --schema ./prisma/schema.prisma",
        "prisma:migrate:deploy": "prisma migrate deploy --schema ./prisma/schema.prisma",
        "db:push": "prisma db push --schema ./prisma/schema.prisma",
        "db:seed": "prisma db seed --schema ./prisma/schema.prisma",
        "db:studio": "prisma studio --schema ./prisma/schema.prisma"
    },
    "dependencies": {
      "@nestjs/common": "^11.0.0",
      "@nestjs/core": "^11.0.0",
      "@nestjs/microservices": "^11.0.0",
      "@prisma/client": "^5.18.0",
      "reflect-metadata": "^0.2.2",
      "rxjs": "^7.8.1"
    },
    "devDependencies": {
      "prisma": "^5.18.0",
      "typescript": "^5.4.0"
    }
  }
  