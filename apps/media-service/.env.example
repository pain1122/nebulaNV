DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nebula_media?schema=public
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nebula_media_shadow2?schema=public
GATEWAY_SECRET="superlongrandomkeyhere"
GATEWAY_SECRET_OLD="superlongrandomkeyhere"
SVC_NAME=media-service
PORT=3007
GRPC_PORT=50058

MEDIA_STORAGE_DRIVER=s3
MEDIA_STORAGE_PROVIDER=minio
MEDIA_S3_ENDPOINT=http://127.0.0.1:9000
MEDIA_S3_INTERNAL_ENDPOINT=http://127.0.0.1:9000
MEDIA_S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MEDIA_S3_REGION=us-east-1
MEDIA_S3_BUCKET=media
MEDIA_S3_ACCESS_KEY=${MINIO_ROOT_USER:-minioadmin}
MEDIA_S3_SECRET_KEY=${MINIO_ROOT_PASSWORD:-minioadmin123}
MEDIA_S3_FORCE_PATH_STYLE=true
MEDIA_SIGNED_UPLOAD_TTL_SECONDS=600
MEDIA_SIGNED_READ_TTL_SECONDS=300
MEDIA_STRICT_READ_TTL_SECONDS=30
MEDIA_PUBLIC_FOLDER=uploads
MEDIA_PRIVATE_FOLDER=private/objects
MEDIA_SYSTEM_FOLDER=system
