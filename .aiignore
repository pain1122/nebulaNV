# AI context/execution exclude list
# Keep source/config examples/docs visible; ignore generated/build/vendor/heavy/secret artifacts.

# Secrets and local env files
.env
.env.*
!.env.example
!**/.env.example
apps/*/.env
apps/*/.env.*
!apps/*/.env.example

# Dependency trees / build outputs
node_modules/
dist/
build/
.next/
.nuxt/
coverage/
.turbo/
.nx/
.cache/
.buildx-cache/
.pnpm-store/
pnpm-store/

# Generated / vendored
generated/
vendor/
prisma/generated/
**/prisma/generated/

# Logs / transient AI run artifacts
*.log
.codex-run-logs/
.codex-web-lint.log

# Large archive and binary assets
*.zip
*.tar
*.gz
*.7z
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.mp4
*.webm
*.pdf

# Bundled vendor artifacts and sourcemaps
*.min.js
*.map
apps/web/public/assets/libs/
apps/web/public/assets/images/
apps/web/public/assets/fonts/
