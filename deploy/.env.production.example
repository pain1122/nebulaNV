# Copy this file to deploy/.env.production on the deployment machine.
# Keep real production secrets out of git.

NEBULA_IMAGE_PREFIX=nebulanv-main
NEBULA_IMAGE_TAG=latest

NODE_ENV=production
PUBLIC_MODE=GATEWAY_ONLY

# Use long random values in real deployments.
GATEWAY_HEADER=x-gateway-sign
GATEWAY_SECRET=change-me-gateway-secret
JWT_ACCESS_SECRET=change-me-jwt-access-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
S2S_SECRET=change-me-s2s-secret
S2S_SECRET_OLD=
S2S_ALLOWED_SERVICES=auth-service,user-service,settings-service,blog-service,product-service,media-service,taxonomy-service,order-service
S2S_GATEWAY_SERVICES=gateway,web

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=nebula
POSTGRES_HOST_PORT=15432

REDIS_HOST_PORT=6379
REDIS_PASSWORD=

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_HOST_PORT=9000
MINIO_CONSOLE_PORT=9001

MEDIA_S3_REGION=us-east-1
MEDIA_S3_BUCKET=media
MEDIA_STORAGE_PROVIDER=minio
MEDIA_S3_INTERNAL_ENDPOINT=http://minio:9000
MEDIA_S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MEDIA_S3_ACCESS_KEY=minioadmin
MEDIA_S3_SECRET_KEY=change-me-minio-password
MEDIA_S3_FORCE_PATH_STYLE=true
MEDIA_SIGNED_UPLOAD_TTL_SECONDS=600
MEDIA_SIGNED_READ_TTL_SECONDS=300
MEDIA_STRICT_READ_TTL_SECONDS=30
MEDIA_PUBLIC_FOLDER=uploads
MEDIA_PRIVATE_FOLDER=private/objects
MEDIA_SYSTEM_FOLDER=system

USER_HTTP_PORT=3100
USER_GRPC_PORT=50051
AUTH_HTTP_PORT=3001
AUTH_GRPC_PORT=50052
PRODUCT_HTTP_PORT=3003
PRODUCT_GRPC_PORT=50053
SETTINGS_HTTP_PORT=3010
SETTINGS_GRPC_PORT=50054
BLOG_HTTP_PORT=3004
BLOG_GRPC_PORT=50055
ORDER_HTTP_PORT=3005
ORDER_GRPC_PORT=50056
TAXONOMY_HTTP_PORT=3006
TAXONOMY_GRPC_PORT=50057
MEDIA_HTTP_PORT=3007
MEDIA_GRPC_PORT=50058
