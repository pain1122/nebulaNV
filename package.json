{
  "name": "nebula-nv",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "proto:gen": "node ./scripts/proto-gen.mjs",
    "proto:check": "node ./scripts/proto-gen.mjs --check",
    "prisma:gen:services": "pnpm -r -F @nebula/settings-service -F @nebula/product-service -F @nebula/user-service exec prisma generate -- --schema ./prisma/schema.prisma",
    "prisma:migrate:services": "pnpm -r --workspace-concurrency=1 -F @nebula/settings-service -F @nebula/product-service -F @nebula/user-service exec prisma migrate dev -- --schema ./prisma/schema.prisma",
    "db:deploy": "pnpm -F @nebula/auth-service prisma:migrate:deploy && pnpm -F @nebula/user-service prisma:migrate:deploy && pnpm -F @nebula/product-service prisma:migrate:deploy && pnpm -F @nebula/settings-service prisma:migrate:deploy"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "jest": "^30.2.0",
    "nx": "^21.5.3",
    "prettier": "^3.6.2",
    "prisma": "6.16.2",
    "proto": "^1.0.19",
    "protoc": "^32.1.0",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.7.7",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.9.0",
    "@grpc/grpc-js": "^1.14.0",
    "@grpc/proto-loader": "^0.8.0",
    "@nestjs/common": "11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "11.1.6",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "11.1.6",
    "@nestjs/platform-express": "11.1.6",
    "@prisma/client": "6.16.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "express": "^5.1.0",
    "joi": "^18.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@nestjs/common": "11.1.5",
      "@nestjs/core": "11.1.5",
      "@nestjs/microservices": "11.1.5",
      "@nestjs/platform-express": "11.1.5",
      "@nestjs/testing": "11.1.5",
      "prisma": "6.11.1",
      "@prisma/client": "6.11.1",
      "fstream": ">=1.0.13",
      "npmlog": "^7.0.1",
      "gauge": "^5.0.0",
      "are-we-there-yet": "^3.0.1",
      "inflight": "^2.0.0",
      "node-domexception": "^2.0.0",
      "glob": "^10.4.5",
      "rimraf": "^6.0.1"
    }
  }
}