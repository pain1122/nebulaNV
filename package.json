    "prettier": "^3.6.0",
    "prisma": "^6.11.1",
    "proto": "^1.0.19",
    "protoc": "^1.1.3",
    "ts-proto": "^2.7.5",
    "turbo": "^2.5.4",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.20.0"
  },
